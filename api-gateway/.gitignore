# =========================================================================
# Microservices Root Gitignore
# =========================================================================

# 1. Ignore node_modules in any service/subfolder
**/node_modules/
node_modules/

# 2. Ignore all environment variables & secrets (Crucial for security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# 3. Ignore logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment variables (Sensitive Data)
.env
.env.local
*.env

# Operating System Files
.DS_Store
Thumbs.db

# Large Dependency Folders
node_modules/
.venv/
env/
# Root .gitignore
.DS_Store
Thumbs.db
.vscode/
.idea/
*.env
*.log
node_modules/